<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <title>@ViewData["Title"] - ATPBCauaLeal</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/css/cerulean.min.css"/>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>

<body>

<div class="app-container d-flex">

    <aside class="sidebar text-white p-3">

        <div class="sidebar-title mb-4">
            <h4 class="m-0">ATPB</h4>
            <small class="text-muted">Sistema Acadêmico</small>
        </div>

        <nav class="nav flex-column">

            @if (User.IsInRole("Admin"))
            {
                <a class="nav-link sidebar-link" asp-page="/Admin/Painel">
                    <i class="bi bi-speedometer2 me-2"></i> Painel
                </a>

                <a class="nav-link sidebar-link" asp-page="/Admin/Usuarios">
                    <i class="bi bi-people me-2"></i> Usuários
                </a>

                <a class="nav-link sidebar-link" href="#">
                    <i class="bi bi-calendar-week me-2"></i> Turmas
                </a>
            }

            @if (User.IsInRole("Aluno"))
            {
                <a class="nav-link sidebar-link" asp-page="/Aluno/Painel">
                    <i class="bi bi-speedometer2 me-2"></i> Painel
                </a>

                <a class="nav-link sidebar-link" asp-page="/Aluno/PlanoDeEstudos">
                    <i class="bi bi-book me-2"></i> Plano de Estudos
                </a>

                <a class="nav-link sidebar-link" asp-page="/Aluno/Matricula">
                    <i class="bi bi-calendar-check me-2"></i> Matrícula
                </a>
            }

            @if (!User.Identity?.IsAuthenticated ?? true)
            {
                <a class="nav-link sidebar-link" asp-page="/Index">
                <i class="bi bi-speedometer2 me-2"></i> Painel
                </a>
            }

        </nav>

    </aside>

    <div class="content-area flex-grow-1">

        <header class="topbar shadow-sm px-4 d-flex align-items-center justify-content-between">

            <span class="fw-semibold">
                Sistema Acadêmico
            </span>

            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    @DateTime.Now.ToString("dd/MM/yyyy")
                </span>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-muted small">
                        @User.Identity.Name
                    </span>

                    <form method="post" asp-page="/Index" asp-page-handler="Logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                            Sair
                        </button>
                    </form>
                }
            </div>

        </header>

       <main class="p-4">

            @RenderBody()

        </main>

    </div>

</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
