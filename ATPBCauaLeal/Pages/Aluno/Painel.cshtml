@page
@model ATPBCauaLeal.Pages.Aluno.PainelModel

@{
    ViewData["Title"] = "Painel do Aluno";
}

<h2 class="mb-4">Painel do Aluno</h2>

<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Status da Matricula</h6>
            <h4 class="text-success">Ativa</h4>
        </div>
    </div>

   <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Plano de Estudos</h6>
            <h4>Sim</h4>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Disciplinas no Plano</h6>
            <h4>5</h4>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Orientador</h6>
            <h4>Nao definido</h4>
        </div>
    </div>

</div>

<div class="card shadow-sm p-3">

    <h5>Visao Geral do Curso</h5>

    <p class="text-muted mb-2">
        Aqui voce acompanha o andamento do seu curso, plano de estudos e vinculo com orientador.
    </p>

    <p class="mb-0">
        Utilize o menu lateral para acessar funcionalidades como:
        <strong>Plano de Estudos, Matricula, Historico e Turmas</strong>.
    </p>

</div>
