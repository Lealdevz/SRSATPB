@page
@model AlunoDashboardModel

@{
    ViewData["Title"] = "Dashboard do Aluno";
}

<h2 class="mb-4">Dashboard do Aluno</h2>

<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Status da Matrícula</h6>
            <h4 class="text-success">Ativa</h4>
        </div>
    </div>

   <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Plano de Estudos</h6>
            <h4>Sim</h4>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Disciplinas no Plano</h6>
            <h4>5</h4>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6 class="text-muted">Orientador</h6>
            <h4>Não definido</h4>
        </div>
    </div>

</div>

<div class="card shadow-sm p-3">

    <h5>📊 Visão Geral do Curso</h5>

    <p class="text-muted mb-2">
        Aqui você acompanha o andamento do seu curso, plano de estudos e vínculo com orientador.
    </p>

    <p class="mb-0">
        Utilize o menu lateral para acessar funcionalidades como:
        <strong>Plano de Estudos, Matrícula, Histórico e Turmas</strong>.
    </p>

</div>